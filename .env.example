# Environment Configuration - Copy to .env and update with actual values

# Application
PROJECT_NAME=Vibe Scanner
API_V1_STR=/api/v1

# Security - MUST be changed for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Database
# Development: sqlite+aiosqlite:///./vibe.db
# Production: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./vibe.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# API Security
# Rate limiting
API_RATE_LIMIT=5/minute

# CORS origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost"]

# Scanner settings
MAX_PAGES_TO_CRAWL=500
CRAWLER_TIMEOUT=10.0
CRAWLER_CONCURRENCY=10
